@inject IJSRuntime Js
@implements IAsyncDisposable
@implements IModalContext
@rendermode InteractiveWebAssembly

@* TODO(2026-03-15): Locked=true 時は closedby="none" を設定すべきだが、Firefox が closedby 属性未対応のため
         InvalidCharacterError が発生する。Firefox が closedby をサポートした時点で
         null を "none" に変更すること。ESC 防止は暫定的に @oncancel:preventDefault で対処。 *@
<dialog class="dialog" closedby="@(Locked ? null : "any")" @ref="dialogElement" @oncancel="HandleCancel"
        @oncancel:preventDefault="Locked" @onclose="HandleClose">
    @ChildContent?.Invoke(this)
</dialog>

@code {

    /// <summary>
    /// jsモジュール
    /// </summary>
    private IJSObjectReference? jsModule;

    /// <summary>
    /// ダイアログ参照
    /// </summary>
    private ElementReference dialogElement;

    /// <summary>
    /// 子要素
    /// </summary>
    [Parameter]
    public RenderFragment<IModalContext>? ChildContent { get; set; }

    /// <summary>
    /// [キャンセル状態で]モーダルを閉じた際に発生
    /// </summary>
    [Parameter]
    public EventCallback OnCancel { get; set; }

    /// <summary>
    /// [未キャンセル状態で]モーダルを閉じた際に発生
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>
    /// ユーザー操作による閉じるを禁止するか
    /// </summary>
    [Parameter]
    public bool Locked { get; set; }

    /// <summary>
    /// キャンセルされたか？フラグ(画面が閉じる際にfalseにする)
    /// </summary>
    private bool isCancel = false;

    /// <summary>
    /// jsModule初期化前にOpen()が呼ばれた場合の保留フラグ
    /// </summary>
    private bool pendingOpen = false;

    /// <summary>
    /// 状態を初期化する
    /// </summary>
    private void OnInitState()
    {
        isCancel = false;
    }

    /// <summary>
    /// キャンセル(外部から呼ばれる場合)
    /// </summary>
    public async Task Cancel()
    {
        if (jsModule == null) { return; }
        isCancel = true;
        await jsModule.InvokeVoidAsync("close", dialogElement);
    }

    /// <summary>
    /// 閉じる(外部から呼ばれる場合)
    /// </summary>
    public async Task Close()
    {
        if (jsModule == null) { return; }
        await jsModule.InvokeVoidAsync("close", dialogElement);
    }

    /// <summary>
    /// 開く
    /// </summary>
    public async Task Open()
    {
        if (jsModule == null) { pendingOpen = true; return; }
        await jsModule.InvokeVoidAsync("showModal", dialogElement);
    }

    /// <summary>
    /// キャンセル
    /// </summary>
    private async Task HandleCancel()
    {
        if (Locked) { return; }
        isCancel = true;
    }

    /// <summary>
    /// 閉じる
    /// </summary>
    private async Task HandleClose()
    {
        if (isCancel)
        {
            await OnCancel.InvokeAsync();
        }
        else
        {
            await OnClose.InvokeAsync();
        }
        // 状態を初期化
        OnInitState();
    }

    /// <summary>
    /// レンダリング後
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) { return; }
        jsModule = await Js.InvokeAsync<IJSObjectReference>("import", "/Components/Modals/Modal.razor.js");
        if (pendingOpen)
        {
            pendingOpen = false;
            await jsModule.InvokeVoidAsync("showModal", dialogElement);
        }
    }

    /// <summary>
    /// 破棄処理
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (jsModule == null) { return; }
        await jsModule.DisposeAsync();
        jsModule = null;
    }

}
