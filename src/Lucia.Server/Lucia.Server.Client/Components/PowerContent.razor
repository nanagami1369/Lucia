@using Lucia.Server.Client.HubClients
@using Lucia.Server.Client.Components.Modals
@inject IServiceProvider Services
@rendermode InteractiveWebAssembly
@inject IJSRuntime JSRuntime

<ConfirmModal @ref="confirmModal" />

@if (remainingTime != null)
{
    <div class="schedule-shutdown-card">
        <span> ⏰ シャットダウン予定: @DateTimeOffset.Now.Add(remainingTime.Value).ToString("hh:mm:ss") (残り @remainingTime?.ToString("hh':'mm':'ss"))</span>
        <button class="cancel-schedule-shutdown-button" @onclick="CancelScheduleShutdown">キャンセル</button>
    </div>
}
<div class="power-control-container">
    <button class="restart-button" @onclick="ConfirmRestart">再起動</button>
    <button class="shutdown-button" @onclick="ConfirmShutdown">シャットダウン</button>
    <button class="schedule-shutdown-button" @onclick="ConfirmRegisterScheduleShutdown">予約シャットダウン(2時間後)</button>
</div>

@code {

    /// <summary>
    /// 確認モーダルの参照
    /// </summary>
    private ConfirmModal? confirmModal;

    /// <summary>
    /// 電源管理ハブ クライアント
    /// </summary>
    private PowerHubClient? PowerHubClient { get; set; }

    /// <summary>
    /// 残り時間(予約シャットダウン時)
    /// <summary>
    private TimeSpan? remainingTime { get; set; }

    /// <summary>
    /// レンダリング時
    /// </summary>
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) { return; }
        if (Services.GetService<PowerHubClient>() is { } hubClient)
        {
            PowerHubClient = hubClient;
            PowerHubClient.UpdateScheduleShutdown += HandleUpdateScheduleShutdown;
            PowerHubClient.StateChanged += HandleStateChanged;
        }
    }

    /// <summary>
    /// 破棄処理
    /// </summary>
    public void Dispose()
    {
        if (PowerHubClient != null)
        {
            PowerHubClient.UpdateScheduleShutdown -= HandleUpdateScheduleShutdown;
            PowerHubClient.StateChanged -= HandleStateChanged;
        }
    }

    /// <summary>
    /// 予約シャットダウンの更新時に発生
    /// </summary>
    /// <param name="remainingTime">残り時間</param>
    private void HandleUpdateScheduleShutdown(TimeSpan? remainingTime)
    {
        this.remainingTime = remainingTime;
        StateHasChanged();
    }

    /// <summary>
    /// Hubのステータスが変更された場合
    /// </summary>
    /// <param name="state">状態</param>
    private async void HandleStateChanged(HubClientState state, Exception? _)
    {
        if (PowerHubClient is null) { return; }
        // 接続された時
        if (state is HubClientState.Connected)
        {
            try
            {
                var sessionInfoList = await PowerHubClient.GetScheduleShutdown();
                HandleUpdateScheduleShutdown(sessionInfoList);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", ex.Message);
            }
        }
    }

    /// <summary>
    /// シャットダウンの確認モーダルを表示し、承認された場合にシャットダウンを実行する
    /// </summary>
    private async Task ConfirmShutdown()
    {
        if (confirmModal is null) { return; }
        var confirmed = await confirmModal.Confirm(
            ConfirmType.Danger.Create("シャットダウン確認", "このサーバーをシャットダウンしますか？", "シャットダウンする", "キャンセル")
        );
        if (!confirmed) { return; }
        await Shutdown();
    }

    /// <summary>
    /// 再起動の確認モーダルを表示し、承認された場合に再起動を実行する
    /// </summary>
    private async Task ConfirmRestart()
    {
        if (confirmModal is null) { return; }
        var confirmed = await confirmModal.Confirm(
            ConfirmType.Warm.Create("再起動確認", "このサーバーを再起動しますか？", "再起動する", "キャンセル")
        );
        if (!confirmed) { return; }
        await Restart();
    }

    /// <summary>
    /// 予約シャットダウンの確認モーダルを表示し、承認された場合に予約を登録する
    /// </summary>
    private async Task ConfirmRegisterScheduleShutdown()
    {
        if (confirmModal is null) { return; }
        var executeAt = DateTimeOffset.Now.AddHours(2);
        var confirmed = await confirmModal.Confirm(
            ConfirmType.Info.Create("予約シャットダウン確認", $"2時間後 ({executeAt:HH:mm}) にシャットダウンを予約しますか？", "予約する", "キャンセル")
        );
        if (!confirmed) { return; }
        await RegisterScheduleShutdown(executeAt);
    }

    /// <summary>
    /// シャットダウン
    /// </summary>
    private async Task Shutdown()
    {
        if (PowerHubClient is null) { return; }
        try
        {
            await PowerHubClient.Shutdown();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

    /// <summary>
    /// 再起動
    /// </summary>
    private async Task Restart()
    {
        if (PowerHubClient is null) { return; }
        try
        {
            await PowerHubClient.Restart();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

    /// <summary>
    /// シャットダウンを予約する
    /// </summary>
    /// <param name="executeAt">シャットダウン実行日時</param>
    private async Task RegisterScheduleShutdown(DateTimeOffset executeAt)
    {
        if (PowerHubClient is null) { return; }
        try
        {
            await PowerHubClient.RegisterScheduleShutdown(executeAt);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

    /// <summary>
    /// 現在の予約シャットダウンをキャンセル
    /// </summary>
    public async Task CancelScheduleShutdown()
    {
        if (PowerHubClient is null) { return; }
        try
        {
            await PowerHubClient.CancelScheduleShutdown();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

}