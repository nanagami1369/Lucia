@using Lucia.Models.Models
@using Lucia.Server.Client.HubClients
@using Lucia.Server.Client.Components.Modals
@inject IServiceProvider Services
@implements IDisposable
@rendermode InteractiveWebAssembly
@inject IJSRuntime JSRuntime

<ConfirmModal @ref="confirmModal" />

<div class="content-description">
    <span class="last-update">
        最終更新：@lastUpdated.ToString("HH:mm:ss")
    </span>
    <button class="restart-rds-button" @onclick="HandleOnClickRestartRdsButton">RDS再起動</button>
</div>
<div class="session-list">
    @foreach (var session in SessionList)
    {
        <SessionCard Session="session" RequestSessionLogoff="HandleRequestSessionLogoff"></SessionCard>
    }
</div>

@code {

    /// <summary>
    /// 確認モーダルの参照
    /// </summary>
    private ConfirmModal? confirmModal;

    /// <summary>
    /// セッション ハブ クライアント
    /// </summary>
    private SessionHubClient? SessionHubClient { get; set; }

    /// <summary>
    /// 最終更新
    /// </summary>
    private DateTime lastUpdated = DateTime.Now;

    /// <summary>
    /// セッションリスト
    /// </summary>
    private SessionInfo[] SessionList { get; set; } = [];

    /// <summary>
    /// レンダリング時
    /// </summary>
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) { return; }
        if (Services.GetService<SessionHubClient>() is { } hubClient)
        {
            SessionHubClient = hubClient;
            SessionHubClient.UpdateSession += UpdateSession;
            SessionHubClient.StateChanged += HandleStateChanged;
        }
    }

    /// <summary>
    /// 破棄処理
    /// </summary>
    public void Dispose()
    {
        if (SessionHubClient != null)
        {
            SessionHubClient.UpdateSession -= UpdateSession;
            SessionHubClient.StateChanged -= HandleStateChanged;
        }
    }

    /// <summary>
    /// セッション更新時
    /// </summary>
    /// <param name="sessions"></param>
    private void UpdateSession(SessionInfo[] sessions)
    {
        lastUpdated = DateTime.Now;
        SessionList = sessions;
        StateHasChanged();
    }

    /// <summary>
    /// Hubのステータスが変更された場合
    /// </summary>
    /// <param name="state">状態</param>
    private async void HandleStateChanged(HubClientState state, Exception? _)
    {
        if (SessionHubClient is null) { return; }
        // 接続された時
        if (state is HubClientState.Connected)
        {
            try
            {
                var sessionInfoList = await SessionHubClient.GetSessions();
                UpdateSession(sessionInfoList);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", ex.Message);
            }
        }
    }

    /// <summary>
    /// RDS再起動ボタン押下時
    /// </summary>
    private async Task HandleOnClickRestartRdsButton()
    {
        if (confirmModal is null) { return; }
        var confirmed = await confirmModal.Confirm(
            ConfirmType.Danger.Create("RDS再起動確認", "RDPサービスを再起動しますか？接続中のセッションは切断されます。", "再起動する", "キャンセル")
        );
        if (!confirmed) { return; }
        if (SessionHubClient is null) { return; }
        try
        {
            await SessionHubClient.RestartRdp();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

    /// <summary>
    /// 切断ボタン押下時
    /// </summary>
    /// <param name="sessionId">セッションID</param>
    private async Task HandleRequestSessionLogoff(int sessionId)
    {
        if (confirmModal is null) { return; }
        var confirmed = await confirmModal.Confirm(
            ConfirmType.Danger.Create("切断確認", "このセッションを切断しますか？", "切断する", "キャンセル")
        );
        if (!confirmed) { return; }
        if (SessionHubClient is null) { return; }
        try
        {
            await SessionHubClient.LogOffSession(sessionId);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", ex.Message);
        }
    }

}
