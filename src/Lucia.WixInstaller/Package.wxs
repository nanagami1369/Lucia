<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package Name="Lucia"
           Manufacturer="morihaya"
           Version="!(bind.FileVersion.LuciaServerExe)"
           UpgradeCode="E8B7F3A1-4C2D-4E5F-9A1B-3C6D8E0F2A4B"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perMachine">

    <SummaryInformation Description="Lucia - Windows RDS ホスト管理ダッシュボード" />

    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)"
                  Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <!-- インストール設定プロパティ（ダイアログのデフォルト値） -->
    <Property Id="PORT" Value="6100" />
    <Property Id="ALLOWED_SUBNET" Value="192.168.0.0/16" />

    <!-- ディレクトリ構造 -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Lucia">

        <!-- メイン実行ファイル + サービス構成 -->
        <Component Id="LuciaServerService" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <File Id="LuciaServerExe"
                Source="$(var.PublishDir)\Lucia.Server.exe"
                KeyPath="yes" />

          <!-- Windows Service 登録（自動起動） -->
          <ServiceInstall Id="LuciaServerServiceInstall"
                          Name="LuciaServer"
                          DisplayName="Lucia Session Monitor"
                          Description="Lucia Windows RDS ホスト管理ダッシュボード サービス"
                          Type="ownProcess"
                          Start="auto"
                          ErrorControl="normal"
                          Arguments="--urls http://0.0.0.0:[PORT]" />

          <!-- サービス制御: インストール時に開始、アンインストール時に停止・削除 -->
          <ServiceControl Id="LuciaServerServiceControl"
                          Name="LuciaServer"
                          Start="install"
                          Stop="both"
                          Remove="uninstall"
                          Wait="yes" />

          <!-- Windows イベントログソース登録 -->
          <util:EventSource Log="Application"
                            Name="LuciaServer"
                            EventMessageFile="[INSTALLFOLDER]Lucia.Server.exe" />

          <!--
            ファイアウォール規則: WiX でポートと基本スコープを設定する。
            Firewall 拡張は RemoteAddresses を未サポートのため、
            サブネット絞り込みは UpdateFirewallSubnet カスタムアクションで行う。
          -->
          <fw:FirewallException Id="LuciaServerFirewall"
                                Name="LuciaServer"
                                Protocol="tcp"
                                Port="[PORT]"
                                Scope="any"
                                Profile="private" />
        </Component>

        <!-- publish 出力の残りファイルを自動収集（Lucia.Server.exe は上で個別定義済み） -->
        <Files Include="$(var.PublishDir)\**">
          <Exclude Files="$(var.PublishDir)\Lucia.Server.exe" />
        </Files>

      </Directory>
    </StandardDirectory>

    <!-- WixUI_InstallDir: インストール先選択付きの標準ダイアログセット -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- ConfigDlg を InstallDirDlg と VerifyReadyDlg の間に挿入 -->
    <UI>
      <!--
        Order=5 で WixUI_InstallDir の既定 NewDialog (Order=4, Value=VerifyReadyDlg) を上書きする。
        条件は既定と同じにして、パス検証が通ったときのみ遷移する。
      -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="ConfigDlg" Order="5"
               Condition="WIXUI_INSTALLDIR_VALID = 1 OR WIXUI_DONTVALIDATEPATH" />
      <Publish Dialog="ConfigDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" />
      <Publish Dialog="ConfigDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" />
    </UI>

    <!-- MIT ライセンス表示 -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!--
      WiX Firewall 拡張が RemoteAddresses 未サポートのため、
      netsh で ALLOWED_SUBNET を反映するカスタムアクションを追加する。
      SetProperty で即時フェーズに ALLOWED_SUBNET の値をキャプチャし、
      遅延 CA に渡す（遅延 CA は直接プロパティを参照できないため）。
    -->
    <SetProperty Id="UpdateFirewallSubnet"
                 Value='netsh advfirewall firewall set rule name="LuciaServer" new remoteip="[ALLOWED_SUBNET]"'
                 Before="UpdateFirewallSubnet"
                 Sequence="execute" />

    <CustomAction Id="UpdateFirewallSubnet"
                  Directory="SystemFolder"
                  ExeCommand="[UpdateFirewallSubnet]"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      WiX Firewall CA がアンインストール時に FW ルールを削除できない（action state 0）ため、
      netsh で明示的に削除するカスタムアクションを追加する。
      REMOVE="ALL" のとき（完全アンインストール・MajorUpgrade での旧バージョン除去）に実行する。
    -->
    <SetProperty Id="RemoveFirewallRule"
                 Value='netsh advfirewall firewall delete rule name="LuciaServer"'
                 Before="RemoveFirewallRule"
                 Sequence="execute" />

    <CustomAction Id="RemoveFirewallRule"
                  Directory="SystemFolder"
                  ExeCommand="[RemoveFirewallRule]"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      WiX util:EventSource CA もアンインストール時に action state 0 で削除できないため、
      reg コマンドで Application イベントログのソースキーを明示削除する。
    -->
    <SetProperty Id="RemoveEventLogSource"
                 Value='reg delete "HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\LuciaServer" /f'
                 Before="RemoveEventLogSource"
                 Sequence="execute" />

    <CustomAction Id="RemoveEventLogSource"
                  Directory="SystemFolder"
                  ExeCommand="[RemoveEventLogSource]"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      WiX ServiceControl の DeleteService はアンインストール後も SCM エントリが
      残ることがある。sc.exe で明示削除して確実にクリーンアップする。
    -->
    <SetProperty Id="DeleteService"
                 Value='sc.exe delete LuciaServer'
                 Before="DeleteService"
                 Sequence="execute" />

    <CustomAction Id="DeleteService"
                  Directory="SystemFolder"
                  ExeCommand="[DeleteService]"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- ファイアウォール規則追加後にサブネットを更新する（インストール・アップグレード時） -->
      <Custom Action="UpdateFirewallSubnet" Before="InstallFinalize"
              Condition="NOT Installed OR REINSTALL" />
      <!-- アンインストール時に FW ルール・EventLog ソース・サービスを明示削除する -->
      <Custom Action="RemoveFirewallRule"    Before="InstallFinalize" Condition='REMOVE = "ALL"' />
      <Custom Action="RemoveEventLogSource"  Before="InstallFinalize" Condition='REMOVE = "ALL"' />
      <Custom Action="DeleteService"         Before="InstallFinalize" Condition='REMOVE = "ALL"' />
    </InstallExecuteSequence>

  </Package>

</Wix>
